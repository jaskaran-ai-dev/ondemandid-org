# Environment Variables Example
# Copy this file to .env and fill in the actual values

# Application
NEXT_PUBLIC_APP_NAME=Your App Name
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Demo Mode
# Set to 'true' to use simulated iVALT responses (for development/testing)
# Set to 'false' or remove to use real iVALT API integration
DEMO_MODE=true

# Database Configuration
# DB_TYPE: 'neon' for PostgreSQL (production) or 'sqlite' for local development
DB_TYPE=sqlite

# PostgreSQL (Neon) - Required if DB_TYPE=neon
DATABASE_URL=postgresql://user:password@host:port/database

# SQLite - Required if DB_TYPE=sqlite (default: ./local.db)
SQLITE_DB_PATH=./local.db

# iVALT API Configuration
# Required for production mode (DEMO_MODE=false)
IVALT_API_KEY=your_ivalt_api_key_here
IVALT_API_BASE_URL=https://api.ivalt.com

# Email Configuration
EMAIL_FROM=noreply@yourdomain.com
ADMIN_EMAIL=admin@yourdomain.com
EMAIL_PROVIDER=ses  # 'ses' for AWS SES or 'smtp' for SMTP

# AWS SES Configuration (if EMAIL_PROVIDER=ses)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# SMTP Configuration (if EMAIL_PROVIDER=smtp or as fallback)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_SECURE=true
